{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },
  "Query": {
    "DefaultTimeoutSeconds": 30,
    "MaxQueryTimeoutSeconds": 300,
    "DefaultCacheTtlSeconds": 300,
    "MaxRowsPerQuery": 100000
  },
  "Upload": {
    "MaxFileSizeMb": 50
  },
  "Jwt": {
    "Issuer": "kinetic",
    "Audience": "kinetic-users",
    "ExpiryMinutes": 60,
    "RefreshExpiryDays": 7,
    "RsaPrivateKeyPem": "",
    "RsaPublicKeyPem": ""
  }
}
