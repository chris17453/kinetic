{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting": "Warning",
      "MassTransit": "Information"
    }
  },
  "ScheduledJobs": {
    "ScheduledReportCheckIntervalMinutes": 5,
    "AuditCleanupIntervalHours": 24,
    "AuditRetentionDays": 90,
    "TempCleanupIntervalMinutes": 60,
    "TempDataMaxAgeMinutes": 1440,
    "EntraSyncIntervalHours": 6,
    "EnableEntraSync": true
  },
  "TempCache": {
    "SchemaName": "kinetic_cache"
  }
}
