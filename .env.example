# Copy to .env and fill in values before running
# NEVER commit .env to version control

# Database
MSSQL_CONNECTION_STRING=Server=mssql;Database=kinetic;User Id=sa;Password=CHANGE_ME;TrustServerCertificate=True
MSSQL_SA_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_CONNECTION_STRING=redis:6379,password=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# Security
JWT_SECRET=CHANGE_ME_min_32_chars_random_string_here
ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_here!

# Optional: Microsoft Entra ID SSO
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENABLE_ENTRA_SYNC=false

# Optional: JWT customization
JWT_ISSUER=kinetic
JWT_AUDIENCE=kinetic-users

# RS256 JWT Keys (recommended for production - base64 encoded PEM)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_RSA_PRIVATE_KEY_PEM=
JWT_RSA_PUBLIC_KEY_PEM=
ENC KEY=Su7kl1bOzPGKp1LNaeDUXRglRWBIkZNaCPYLNL0PRPU=